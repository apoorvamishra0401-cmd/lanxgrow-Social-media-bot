function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var action = data.action;

    if (action === "log_post") {
      var sheet = ss.getSheetByName("Posts");
      sheet.appendRow([
        data.timestamp,
        data.topic,
        data.post_content,
        data.quality_score,
        data.rating,
        data.hook_type_used,
        data.engagement_prediction,
        data.research_sources,
        data.research_content_types,
        data.research_quantity,
        data.what_bot_learned,
        data.improvement_applied,
        data.image_prompt,
        data.video_prompt,
        data.seo_keywords,
        data.trending_topic,
        data.competitor_pattern,
        data.image_url,
        data.video_url,
        data.command_used
      ]);
      return ContentService.createTextOutput(JSON.stringify({status: "ok", action: "log_post"}))
        .setMimeType(ContentService.MimeType.JSON);
    }

    if (action === "update_rating") {
      var sheet = ss.getSheetByName("Posts");
      var data_range = sheet.getDataRange().getValues();
      for (var i = 1; i < data_range.length; i++) {
        if (data_range[i][1] === data.topic) {
          sheet.getRange(i + 1, 5).setValue(data.rating);
          break;
        }
      }
      return ContentService.createTextOutput(JSON.stringify({status: "ok", action: "update_rating"}))
        .setMimeType(ContentService.MimeType.JSON);
    }

    if (action === "log_feedback") {
      var sheet = ss.getSheetByName("Feedback");
      sheet.appendRow([
        data.date,
        data.feedback_text,
        "New",
        ""
      ]);
      return ContentService.createTextOutput(JSON.stringify({status: "ok", action: "log_feedback"}))
        .setMimeType(ContentService.MimeType.JSON);
    }

    if (action === "read_feedback") {
      var sheet = ss.getSheetByName("Feedback");
      var rows = sheet.getDataRange().getValues();
      var feedback = [];
      for (var i = 1; i < rows.length; i++) {
        if (rows[i][2] === "New") {
          feedback.push(rows[i][1]);
          sheet.getRange(i + 1, 3).setValue("Read");
        }
      }
      return ContentService.createTextOutput(JSON.stringify({status: "ok", feedback: feedback.join("\n")}))
        .setMimeType(ContentService.MimeType.JSON);
    }

    if (action === "update_expiry") {
      var sheet = ss.getSheetByName("API Expiry");
      var rows = sheet.getDataRange().getValues();
      for (var i = 1; i < rows.length; i++) {
        if (rows[i][0] === data.api_name) {
          sheet.getRange(i + 1, 3).setValue(data.days_left);
          sheet.getRange(i + 1, 4).setValue(data.last_reminder);
          break;
        }
      }
      return ContentService.createTextOutput(JSON.stringify({status: "ok", action: "update_expiry"}))
        .setMimeType(ContentService.MimeType.JSON);
    }

    return ContentService.createTextOutput(JSON.stringify({status: "error", message: "unknown action"}))
      .setMimeType(ContentService.MimeType.JSON);

  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({status: "error", message: err.toString()}))
      .setMimeType(ContentService.MimeType.JSON);
  }
}
